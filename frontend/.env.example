# Supabase (required for sign-in / Google OAuth)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API (obligatoire en prod pour score/stats à jour sur /app/analyze)
# Local: http://localhost:8000  |  Prod: https://votre-api.railway.app ou https://api.deepfoot.io
NEXT_PUBLIC_API_URL=http://localhost:8000

# App subdomain in production (e.g. https://app.deepfoot.io)
NEXT_PUBLIC_APP_ORIGIN=
