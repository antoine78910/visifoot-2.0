# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=your-anon-key
# Optionnel : pour mettre à jour le plan utilisateur depuis le webhook Whop (recherche par email). Ne pas exposer côté client.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API-Football (https://www.api-football.com/documentation-v3) — stats matchs / équipes
API_FOOTBALL_KEY=your-api-key
# API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# OpenAI (résumé + scénario)
OPENAI_API_KEY=sk-...

# NewsAPI.org (optionnel — actualités pour le quick summary style Visifoot)
# NEWS_API_KEY=your-newsapi-key

# DataFast — attribution revenus (webhook Whop → POST https://datafa.st/api/v1/payments)
# DATAFAST_API_KEY=your-datafast-api-key

# Whop — secret du webhook (vérification signature, ex. ws_...)
# WHOP_WEBHOOK_SECRET=ws_xxxx

# Optionnel
FREE_ANALYSES_PER_DAY=1
MAX_SCORE_GOALS=8

# Polling matchs terminés (FT) : intervalle en secondes pour le script ou le cron
# 10 = test (toutes les 10 s), 3600 = prod (toutes les 1 h)
# POLLING_INTERVAL_SECONDS=10
